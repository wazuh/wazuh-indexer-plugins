{
  "dynamic": "strict_allow_templates",
  "date_detection": false,
  "dynamic_templates": [
    {
      "hash_type_objects": {
        "match_mapping_type": "object",
        "path_match": "type_hashes.*",
        "mapping": {
          "type": "object"
        }
      }
    },
    {
      "hash256": {
        "match_mapping_type": "string",
        "path_match": "type_hashes.*.hash.sha256",
        "mapping": {
          "type": "keyword"
        }
      }
    }
  ]
}