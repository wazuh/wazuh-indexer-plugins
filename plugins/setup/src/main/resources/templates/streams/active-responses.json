{
  "index_patterns": [
    "wazuh-active-responses*"
  ],
  "priority": 1,
  "template": {
    "settings": {
      "index": {
        "auto_expand_replicas": "0-1",
        "max_docvalue_fields_search": 50,
        "number_of_replicas": "0",
        "number_of_shards": "3",
        "query.default_field": [
          "wazuh.agent.id",
          "wazuh.agent.name",
          "wazuh.active_response.name",
          "wazuh.active_response.executable",
          "event.index",
          "event.doc_id"
        ],
        "refresh_interval": "5s"
      },
      "mapping.nested_fields.limit": 10,
      "mapping.total_fields.limit": 500,
      "plugins.index_state_management.rollover_alias": "wazuh-active-responses"
    },
    "mappings": {
      "date_detection": false,
      "dynamic": "strict",
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "event": {
          "properties": {
            "doc_id": {
              "ignore_above": 1024,
              "type": "keyword"
            },
            "index": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        "wazuh": {
          "properties": {
            "active_response": {
              "properties": {
                "agent_id": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "executable": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "extra_arguments": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "location": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "name": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "stateful_timeout": {
                  "type": "integer"
                },
                "type": {
                  "ignore_above": 1024,
                  "type": "keyword"
                }
              }
            },
            "cluster": {
              "properties": {
                "name": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "node": {
                  "ignore_above": 1024,
                  "type": "keyword"
                }
              }
            },
            "integration": {
              "properties": {
                "category": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "decoders": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "name": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "rules": {
                  "ignore_above": 1024,
                  "type": "keyword"
                }
              }
            },
            "protocol": {
              "properties": {
                "location": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "queue": {
                  "type": "byte"
                }
              }
            },
            "schema": {
              "properties": {
                "version": {
                  "ignore_above": 1024,
                  "type": "keyword"
                }
              }
            },
            "space": {
              "properties": {
                "event_discarded": {
                  "type": "boolean"
                },
                "name": {
                  "ignore_above": 1024,
                  "type": "keyword"
                }
              }
            }
          }
        }
      }
    }
  }
}
