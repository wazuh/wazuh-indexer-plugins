{
  "index_patterns": [
    "wazuh-active-responses*"
  ],
  "priority": 1,
  "template": {
    "settings": {
      "index": {
        "auto_expand_replicas": "0-1",
        "max_docvalue_fields_search": 50,
        "number_of_replicas": "0",
        "number_of_shards": "3",
        "query.default_field": [
          "wazuh.agent.id",
          "wazuh.agent.name",
          "wazuh.active_response.name",
          "wazuh.active_response.executable",
          "event.index",
          "event.doc_id"
        ],
        "refresh_interval": "5s"
      },
      "mapping.nested_fields.limit": 10,
      "mapping.total_fields.limit": 500,
      "plugins.index_state_management.rollover_alias": "wazuh-active-responses"
    },
    "mappings": {
      "date_detection": false,
      "dynamic": "false_allow_templates",
      "dynamic_templates": [
        {
          "wcs_event_doc_id": {
            "path_match": "event.doc_id",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_event_index": {
            "path_match": "event.index",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_active_response_agent_id": {
            "path_match": "wazuh.active_response.agent_id",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_active_response_executable": {
            "path_match": "wazuh.active_response.executable",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_active_response_extra_arguments": {
            "path_match": "wazuh.active_response.extra_arguments",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_active_response_location": {
            "path_match": "wazuh.active_response.location",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_active_response_name": {
            "path_match": "wazuh.active_response.name",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_active_response_stateful_timeout": {
            "path_match": "wazuh.active_response.stateful_timeout",
            "mapping": {
              "type": "integer"
            }
          }
        },
        {
          "wcs_wazuh_active_response_type": {
            "path_match": "wazuh.active_response.type",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_cluster_name": {
            "path_match": "wazuh.cluster.name",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_cluster_node": {
            "path_match": "wazuh.cluster.node",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_integration_category": {
            "path_match": "wazuh.integration.category",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_integration_decoders": {
            "path_match": "wazuh.integration.decoders",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_integration_name": {
            "path_match": "wazuh.integration.name",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_integration_rules": {
            "path_match": "wazuh.integration.rules",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_protocol_location": {
            "path_match": "wazuh.protocol.location",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_protocol_queue": {
            "path_match": "wazuh.protocol.queue",
            "mapping": {
              "type": "byte"
            }
          }
        },
        {
          "wcs_wazuh_schema_version": {
            "path_match": "wazuh.schema.version",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        {
          "wcs_wazuh_space_event_discarded": {
            "path_match": "wazuh.space.event_discarded",
            "mapping": {
              "type": "boolean"
            }
          }
        },
        {
          "wcs_wazuh_space_name": {
            "path_match": "wazuh.space.name",
            "mapping": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        }
      ],
      "properties": {
        "event": {
          "properties": {}
        },
        "wazuh": {
          "properties": {
            "active_response": {
              "properties": {}
            },
            "cluster": {
              "properties": {}
            },
            "integration": {
              "properties": {}
            },
            "protocol": {
              "properties": {}
            },
            "schema": {
              "properties": {}
            },
            "space": {
              "properties": {}
            }
          }
        },
        "@timestamp": {
          "type": "date"
        }
      }
    }
  }
}
