{
  "index_patterns": [
    "wazuh-events-v5-unclassified*"
  ],
  "priority": 1,
  "data_stream": {},
  "template": {
    "settings": {
      "index": {
        "auto_expand_replicas": "0-1",
        "max_docvalue_fields_search": 50,
        "number_of_replicas": "0",
        "number_of_shards": "3",
        "query.default_field": [
          "wazuh.agent.id",
          "wazuh.agent.name",
          "wazuh.cluster.name",
          "wazuh.space.name"
        ],
        "refresh_interval": "5s"
      },
      "mapping.nested_fields.limit": 10,
      "mapping.total_fields.limit": 500,
      "plugins.index_state_management.rollover_alias": "wazuh-events-v5-unclassified"
    },
    "mappings": {
      "date_detection": false,
      "dynamic": "false_allow_templates",
      "dynamic_templates": [],
      "properties": {
        "event": {
          "properties": {}
        },
        "wazuh": {
          "properties": {
            "agent": {
              "properties": {
                "build": {
                  "properties": {}
                },
                "host": {
                  "properties": {
                    "boot": {
                      "properties": {}
                    },
                    "cpu": {
                      "properties": {}
                    },
                    "disk": {
                      "properties": {
                        "read": {
                          "properties": {}
                        },
                        "write": {
                          "properties": {}
                        }
                      }
                    },
                    "geo": {
                      "properties": {}
                    },
                    "memory": {
                      "properties": {
                        "used": {
                          "properties": {}
                        }
                      }
                    },
                    "network": {
                      "properties": {
                        "egress": {
                          "properties": {}
                        },
                        "ingress": {
                          "properties": {}
                        }
                      }
                    },
                    "os": {
                      "properties": {}
                    },
                    "risk": {
                      "properties": {}
                    }
                  }
                }
              }
            },
            "cluster": {
              "properties": {}
            },
            "integration": {
              "properties": {}
            },
            "protocol": {
              "properties": {}
            },
            "schema": {
              "properties": {}
            },
            "space": {
              "properties": {}
            }
          }
        },
        "@timestamp": {
          "type": "date"
        }
      }
    }
  }
}
