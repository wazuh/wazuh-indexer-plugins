{
  "index_patterns": [
    "wazuh-metrics-normalization*"
  ],
  "priority": 1,
  "data_stream": {},
  "template": {
    "settings": {
      "index": {
        "number_of_replicas": "0",
        "number_of_shards": "1",
        "query.default_field": [
          "event.module",
          "event.kind",
          "metric.name",
          "metric.type",
          "wazuh.cluster.name",
          "wazuh.cluster.node",
          "wazuh.space.name",
          "wazuh.schema.version"
        ],
        "refresh_interval": "5s"
      },
      "mapping.total_fields.limit": 1000,
      "plugins.index_state_management.policy_id": "stream-metrics-policy",
      "plugins.index_state_management.rollover_alias": "wazuh-metrics-normalization"
    },
    "mappings": {
      "date_detection": false,
      "dynamic": "strict",
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "event": {
          "properties": {
            "kind": {
              "ignore_above": 1024,
              "type": "keyword"
            },
            "module": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        "metric": {
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "name": {
              "ignore_above": 1024,
              "type": "keyword"
            },
            "type": {
              "ignore_above": 1024,
              "type": "keyword"
            },
            "value": {
              "type": "float"
            }
          }
        },
        "wazuh": {
          "properties": {
            "cluster": {
              "properties": {
                "name": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "node": {
                  "ignore_above": 1024,
                  "type": "keyword"
                }
              }
            },
            "schema": {
              "properties": {
                "version": {
                  "ignore_above": 1024,
                  "type": "keyword"
                }
              }
            },
            "space": {
              "properties": {
                "name": {
                  "ignore_above": 1024,
                  "type": "keyword"
                }
              }
            }
          }
        }
      }
    }
  }
}
