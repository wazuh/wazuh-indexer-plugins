{
  "index_patterns": [
    ".wazuh-setup-status*"
  ],
  "priority": 1,
  "template": {
    "settings": {
      "index": {
        "codec": "zstd",
        "hidden": true,
        "number_of_replicas": "0",
        "number_of_shards": "1",
        "refresh_interval": "-1"
      }
    },
    "mappings": {
      "date_detection": false,
      "dynamic": "strict",
      "properties": {
        "status": {
          "type": "keyword"
        },
        "timestamp": {
          "type": "date"
        }
      }
    }
  }
}
