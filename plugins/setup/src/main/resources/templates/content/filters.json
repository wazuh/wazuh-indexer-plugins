{
  "index_patterns": [
    "wazuh-threatintel-filters"
  ],
  "priority": 1,
  "template": {
    "settings": {
      "index": {
        "auto_expand_replicas": "0-1",
        "codec": "zstd",
        "max_docvalue_fields_search": 50,
        "number_of_replicas": "0",
        "number_of_shards": "1",
        "query.default_field": [
          "document.name",
          "document.id",
          "document.type",
          "document.check",
          "document.metadata.description",
          "document.metadata.author.name",
          "document.metadata.author.email",
          "document.metadata.author.url",
          "hash.sha256",
          "space.name"
        ],
        "refresh_interval": "5s"
      },
      "mapping.nested_fields.limit": 10
    },
    "mappings": {
      "date_detection": false,
      "dynamic": "strict",
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "document": {
          "properties": {
            "check": {
              "enabled": false,
              "type": "object"
            },
            "enabled": {
              "type": "boolean"
            },
            "id": {
              "ignore_above": 1024,
              "type": "keyword"
            },
            "metadata": {
              "properties": {
                "author": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "date": {
                  "type": "date"
                },
                "description": {
                  "norms": false,
                  "type": "text"
                },
                "documentation": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "modified": {
                  "type": "date"
                },
                "references": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "supports": {
                  "ignore_above": 1024,
                  "type": "keyword"
                },
                "title": {
                  "ignore_above": 1024,
                  "type": "keyword"
                }
              }
            },
            "name": {
              "ignore_above": 1024,
              "type": "keyword"
            },
            "type": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        "hash": {
          "properties": {
            "sha256": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        "space": {
          "properties": {
            "name": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        "yaml": {
          "norms": false,
          "type": "text"
        }
      }
    }
  }
}
