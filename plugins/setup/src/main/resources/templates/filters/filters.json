{
  "index_patterns": [
    ".engine-filters"
  ],
  "priority": 1,
  "template": {
    "settings": {
      "index": {
        "auto_expand_replicas": "0-1",
        "max_docvalue_fields_search": 50,
        "number_of_replicas": "0",
        "number_of_shards": "1",
        "query.default_field": [
          "document.name",
          "document.id",
          "document.type",
          "document.check",
          "document.metadata.description",
          "document.metadata.author.name",
          "document.metadata.author.email",
          "document.metadata.author.url",
          "hash.sha256",
          "space.name"
        ],
        "refresh_interval": "5s"
      },
      "mapping.nested_fields.limit": 10,
      "mapping.total_fields.limit": 500
    },
    "mappings": {
      "date_detection": false,
      "dynamic": "strict",
      "properties": {
        "document": {
          "properties": {
            "check": {
              "ignore_above": 1024,
              "type": "keyword"
            },
            "enabled": {
              "type": "boolean"
            },
            "id": {
              "ignore_above": 1024,
              "type": "keyword"
            },
            "metadata": {
              "properties": {
                "author": {
                  "properties": {
                    "date": {
                      "type": "date"
                    },
                    "email": {
                      "ignore_above": 1024,
                      "type": "keyword"
                    },
                    "modified": {
                      "type": "date"
                    },
                    "name": {
                      "ignore_above": 1024,
                      "type": "keyword"
                    },
                    "url": {
                      "ignore_above": 1024,
                      "type": "keyword"
                    }
                  }
                },
                "description": {
                  "norms": false,
                  "type": "text"
                }
              }
            },
            "name": {
              "ignore_above": 1024,
              "type": "keyword"
            },
            "type": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        "hash": {
          "properties": {
            "sha256": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        },
        "space": {
          "properties": {
            "name": {
              "ignore_above": 1024,
              "type": "keyword"
            }
          }
        }
      }
    }
  }
}
