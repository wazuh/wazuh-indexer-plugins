{
  "index_patterns": [
    "wazuh-active-responses*"
  ],
  "order": 1,
  "data_stream": {},
  "settings": {
    "plugins.index_state_management.rollover_alias": "wazuh-active-responses",
    "plugins.index_state_management.policy_id": "stream-active-responses-policy",
    "mapping.nested_fields.limit": 10,
    "index": {
      "codec": "zstd",
      "number_of_shards": "3",
      "number_of_replicas": "0",
      "auto_expand_replicas": "0-1",
      "refresh_interval": "5s",
      "query.default_field": [
        "wazuh.agent.id",
        "wazuh.agent.name",
        "wazuh.active_response.name",
        "wazuh.active_response.executable",
        "event.index",
        "event.doc_id"
      ],
      "max_docvalue_fields_search": 50
    },
    "mapping.total_fields.limit": 1000
  }
}
