{
  "index_patterns": [
    "wazuh-findings-v5*"
  ],
  "order": 1,
  "settings": {
    "plugins.index_state_management.rollover_alias": "wazuh-findings-v5",
    "plugins.index_state_management.policy_id": "stream-rollover-policy",
    "mapping.total_fields.limit": 3000,
    "index": {
      "number_of_shards": "3",
      "number_of_replicas": "0",
      "refresh_interval": "2s",
      "query.default_field": [
        "agent.host.architecture",
        "agent.host.ip",
        "agent.id",
        "agent.name",
        "agent.version",
        "wazuh.cluster.name",
        "wazuh.cluster.node",
        "wazuh.schema.version"
      ]
    },
    "mapping.nested_fields.limit": 50
  }
}
