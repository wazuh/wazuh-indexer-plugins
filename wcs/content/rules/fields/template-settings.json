{
  "index_patterns": [
    "wazuh-threatintel-rules"
  ],
  "priority": 1,
  "data_stream": {},
  "template": {
    "settings": {
      "mapping.total_fields.limit": 500,
      "mapping.nested_fields.limit": 20,
      "index": {
        "number_of_shards": "1",
        "number_of_replicas": "0",
        "auto_expand_replicas": "0-1",
        "refresh_interval": "5s",
        "query.default_field": [
          "document.id",
          "document.name",
          "document.level",
          "document.status",
          "document.tags",
          "document.metadata.title",
          "document.metadata.description",
          "document.metadata.author",
          "hash.sha256",
          "space.name",
          "type"
        ],
        "max_docvalue_fields_search": 50
      }
    }
  }
}

